# Copy to .env (git-ignored) and fill in. Loaded + exported by the Makefile,
# so `make dev`/`run`/`worker` pick these up.

# Master key for encrypting stored secrets at rest (Fernet, base64).
# Generate one with:  make secret-key
# Keep it stable — losing it makes previously stored secrets undecryptable.
naaf_secret_key=

# Agent credentials (Anthropic key, GitHub token) are NOT set here — enter them
# in the app at Settings > Secrets, where they're encrypted and injected per run.
