# Enable MSW mock service worker for fully-mocked static demo (default).
# Set to "true" when running the UI locally without a backend.
VITE_USE_MOCKS=true

# Hybrid live-API mode: when "true", only the mock-only handlers (runs, agents,
# inbox, threads, dashboard, budget) are intercepted by MSW.  All other paths
# (/api/projects, /api/work-items, /api/teams, /api/agent-definitions) bypass
# the mock and are proxied by Vite to the real backend on http://localhost:8000.
#
# Usage:
#   cd projects/server && make run          # backend on :8000
#   cd projects/ui && VITE_LIVE_API=true pnpm dev
VITE_LIVE_API=false
